{
  "Rag": {
    "StorageProvider": "Minio"
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "WithSsl": false,
    "Bucket": "rag-documents"
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "QueueName": "rag.index",
    "ConnectionRetryDelaySeconds": 5
  },
  "HuggingFace": {
    "Dataset": "rag-datasets/rag-mini-wikipedia",
    "Config": "text-corpus",
    "Split": "passages",
    "BatchSize": 100
  },
  "Seeder": {
    "Collection": "wikipedia",
    "MaxDocuments": 0,
    "IndexQueueName": "rag.index"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
